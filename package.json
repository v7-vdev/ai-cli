{
  "name": "ork-cli",
  "version": "1.0.0",
  "description": "Trust-Oriented Orchestration Runtime",
  "main": "dist/index.js",
  "bin": {
    "ork": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "package": "npm run build && pkg package.json",
    "release": "node scripts/release.js",
    "test": "node --test --import tsx src/tests/*.test.ts"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-linux-x64"
    ],
    "outputPath": "./bin"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "react-devtools-core": "^7.0.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@clack/prompts": "^1.4.0",
    "@google/genai": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "ink": "^7.0.3",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^9.4.0",
    "react": "^19.2.6",
    "zod": "^4.4.3"
  }
}
